# Environment variables template
# Copy this file to `.env` and fill in the values for local development.
# For Vercel, add these variables in your project settings under Settings > Environment Variables.
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Lovable Cloud / Supabase (only needed if you enable Lovable Cloud or connect a Supabase project)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
